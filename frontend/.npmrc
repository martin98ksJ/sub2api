legacy-peer-deps=true
# 允许运行所有包的构建脚本
# esbuild 和 vue-demi 是已知安全的包，需要 postinstall 脚本才能正常工作
ignore-scripts=false
# pnpm v10+ blocks dependency lifecycle scripts by default for security.
# This setting allows all dependencies to run build scripts (equivalent of ignore-scripts=false in pnpm v9).
onlyBuiltDependencies=*
